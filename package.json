{
  "name": "knx.ts",
  "version": "1.0.0",
  "description": "A high-performance KNXnet/IP server and client library in TypeScript, focused on ETS stability.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "tsc && node dist/index.js",
    "watch": "tsc -w",
    "test:connection": "node dist/test/knxd_manual.test.js",
    "test:routing": "node dist/test/routing_manual.test.js",
    "test:controlField": "node dist/test/controlField.test.js"
  },
  "keywords": [
    "knx",
    "knxnetip",
    "tunnelling",
    "routing",
    "automation",
    "smarthome",
    "typescript"
  ],
  "author": "Arnold Steven Beleño Zuletta (Wesxt)",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.13",
    "@types/pino": "^7.0.4",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "serialport": "^13.0.0"
  }
}
